when(userRepository.<span class="mt">findById</span>(<span class="vl">999L</span>)).<span class="mt">thenReturn</span>(Optional.<span class="mt">empty</span>());  <span class="cm">// 未発見</span>
when(userRepository.<span class="mt">findAll</span>()).<span class="mt">thenReturn</span>(List.<span class="mt">of</span>(mockUser));
​
<span class="cm">// ② 任意の引数にマッチ</span>
when(userRepository.<span class="mt">existsByEmail</span>(anyString())).<span class="mt">thenReturn</span>(<span class="vl">false</span>);
when(userRepository.<span class="mt">findById</span>(anyLong())).<span class="mt">thenReturn</span>(Optional.<span class="mt">of</span>(mockUser));
​
<span class="cm">// ③ 例外を投げさせる</span>
when(userRepository.<span class="mt">save</span>(any())).<span class="mt">thenThrow</span>(<span class="kw">new</span> <span class="tp">DataAccessException</span>(<span class="st">"DB Error"</span>){});
​
<span class="cm">// ④ 呼び出し回数を検証（verify）</span>
verify(userRepository, times(<span class="vl">1</span>)).<span class="mt">save</span>(any());     <span class="cm">// 1回呼ばれたか</span>
verify(userRepository, never()).<span class="mt">delete</span>(any());   <span class="cm">// 呼ばれていないか</span>
verify(userRepository, atLeast(<span class="vl">1</span>)).<span class="mt">findById</span>(anyLong());
​
<span class="cm">// ⑤ 引数のキャプチャ（save()に渡されたオブジェクトを検証）</span>
<span class="tp">ArgumentCaptor</span>&lt;<span class="tp">User</span>&gt; captor = ArgumentCaptor.<span class="mt">forClass</span>(<span class="tp">User</span>.<span class="kw">class</span>);
verify(userRepository).<span class="mt">save</span>(captor.<span class="mt">capture</span>());
<span class="tp">User</span> savedUser = captor.<span class="mt">getValue</span>();
assertThat(savedUser.getName()).<span class="mt">isEqualTo</span>(<span class="st">"田中太郎"</span>);
assertThat(savedUser.getDelFlg()).<span class="mt">isFalse</span>();   <span class="cm">// 削除フラグが立っていないか確認</span>
​
<span class="cm">// ⑥ void メソッドのモック（doNothing / doThrow）</span>
doNothing().when(userRepository).<span class="mt">deleteById</span>(anyLong());
doThrow(<span class="kw">new</span> <span class="tp">RuntimeException</span>(<span class="st">"error"</span>)).when(userRepository).<span class="mt">deleteById</span>(<span class="vl">999L</span>);</div>

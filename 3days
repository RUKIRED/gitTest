    <div class="card">
      <h4>標準的な Controller の書き方</h4>
      <div class="code"><span class="an">@RestController</span>                          <span class="cm">// @Controller + @ResponseBody の合体</span>
<span class="an">@RequestMapping</span>(<span class="st">"/api/users"</span>)            <span class="cm">// ベースパス</span>
<span class="an">@RequiredArgsConstructor</span>                  <span class="cm">// Lombok：finalフィールドのコンストラクタを自動生成</span>
<span class="an">@Slf4j</span>                                    <span class="cm">// Lombok：log変数が使えるようになる</span>
<span class="kw">public class</span> <span class="tp">UserController</span> {
​
    <span class="kw">private final</span> <span class="tp">UserService</span> userService;  <span class="cm">// コンストラクタ注入（@Autowiredより推奨）</span>
​
    <span class="cm">// GET /api/users/{id} → ユーザー1件取得</span>
    <span class="an">@GetMapping</span>(<span class="st">"/{id}"</span>)
    <span class="kw">public</span> <span class="tp">ResponseEntity</span>&lt;<span class="tp">UserResponse</span>&gt; <span class="mt">getUser</span>(<span class="an">@PathVariable</span> <span class="tp">Long</span> <span class="pm">id</span>) {
        log.info(<span class="st">"ユーザー取得 id={}"</span>, id);       <span class="cm">// {}でパラメータを埋め込む</span>
        <span class="tp">UserResponse</span> response = userService.<span class="mt">findById</span>(id);
        <span class="kw">return</span> ResponseEntity.<span class="mt">ok</span>(response);    <span class="cm">// 200 OK</span>
    }
​
    <span class="cm">// GET /api/users?status=ACTIVE → 一覧取得</span>
    <span class="an">@GetMapping</span>
    <span class="kw">public</span> <span class="tp">ResponseEntity</span>&lt;<span class="tp">List</span>&lt;<span class="tp">UserResponse</span>&gt;&gt; <span class="mt">listUsers</span>(
            <span class="an">@RequestParam</span>(required = <span class="vl">false</span>) <span class="tp">String</span> <span class="pm">status</span>) {   <span class="cm">// required=false で任意パラメータ</span>
        <span class="kw">return</span> ResponseEntity.<span class="mt">ok</span>(userService.<span class="mt">findAll</span>(status));
    }
​
    <span class="cm">// POST /api/users → ユーザー登録</span>
    <span class="an">@PostMapping</span>
    <span class="kw">public</span> <span class="tp">ResponseEntity</span>&lt;<span class="tp">UserResponse</span>&gt; <span class="mt">createUser</span>(
            <span class="an">@RequestBody</span> <span class="an">@Valid</span> <span class="tp">UserCreateRequest</span> <span class="pm">request</span>) {   <span class="cm">// @Valid でバリデーション実行</span>
        <span class="tp">UserResponse</span> response = userService.<span class="mt">create</span>(request);
        <span class="kw">return</span> ResponseEntity
                .<span class="mt">status</span>(HttpStatus.CREATED)  <span class="cm">// 201</span>
                .<span class="mt">body</span>(response);
    }
​
    <span class="cm">// PUT /api/users/{id} → ユーザー更新</span>
    <span class="an">@PutMapping</span>(<span class="st">"/{id}"</span>)
    <span class="kw">public</span> <span class="tp">ResponseEntity</span>&lt;<span class="tp">UserResponse</span>&gt; <span class="mt">updateUser</span>(
            <span class="an">@PathVariable</span> <span class="tp">Long</span> <span class="pm">id</span>,
            <span class="an">@RequestBody</span> <span class="an">@Valid</span> <span class="tp">UserUpdateRequest</span> <span class="pm">request</span>) {
        <span class="tp">UserResponse</span> response = userService.<span class="mt">update</span>(id, request);
        <span class="kw">return</span> ResponseEntity.<span class="mt">ok</span>(response);
    }
​
    <span class="cm">// DELETE /api/users/{id} → ユーザー削除</span>
    <span class="an">@DeleteMapping</span>(<span class="st">"/{id}"</span>)

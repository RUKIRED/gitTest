<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>3日間集中攻略マニュアル｜現場エンジニア速成ガイド</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;600;700&display=swap');
:root {
  --bg:#07090f;--surface:#0f1521;--surface2:#161e2e;--surface3:#1c2840;
  --border:#1e2d45;--border2:#243352;
  --accent:#38bdf8;--accent2:#818cf8;--accent3:#f59e0b;--accent4:#34d399;
  --text:#e2e8f0;--text-dim:#94a3b8;--text-muted:#4a6080;
  --day1:#38bdf8;--day2:#818cf8;--day3:#34d399;--day4:#f59e0b;
  --red:#f87171;--orange:#fb923c;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans JP',sans-serif;line-height:1.75;font-size:14px;}
​
/* HERO */
.hero{padding:56px 48px 48px;background:linear-gradient(160deg,#07090f 0%,#0b1220 60%,#070d18 100%);border-bottom:1px solid var(--border);position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-120px;right:-60px;width:600px;height:600px;background:radial-gradient(circle,rgba(56,189,248,.05) 0%,transparent 65%);pointer-events:none;}
.hero::after{content:'';position:absolute;bottom:-100px;left:300px;width:400px;height:400px;background:radial-gradient(circle,rgba(129,140,248,.04) 0%,transparent 65%);pointer-events:none;}
.badge{display:inline-block;background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.3);color:var(--accent);font-size:10px;font-weight:700;letter-spacing:3px;padding:3px 12px;border-radius:2px;margin-bottom:18px;text-transform:uppercase;}
.hero h1{font-size:clamp(24px,3.5vw,44px);font-weight:900;line-height:1.2;letter-spacing:-1px;margin-bottom:10px;}
.hero h1 .c1{color:var(--accent);}
.hero h1 .c2{color:var(--accent2);}
.hero-sub{color:var(--text-dim);font-size:13px;max-width:580px;margin-bottom:28px;}
.hero-chips{display:flex;flex-wrap:wrap;gap:8px;}
.chip{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:4px 14px;font-size:11px;color:var(--text-dim);}
​
/* NAV */
.nav{background:var(--surface);border-bottom:1px solid var(--border);display:flex;overflow-x:auto;position:sticky;top:0;z-index:100;padding:0 32px;}
.tab{padding:14px 22px;font-size:12px;font-weight:700;letter-spacing:.5px;color:var(--text-muted);cursor:pointer;border:none;border-bottom:3px solid transparent;background:none;font-family:'Noto Sans JP',sans-serif;white-space:nowrap;transition:color .2s;}
.tab:hover{color:var(--text-dim);}
.tab.a1{color:var(--day1);border-bottom-color:var(--day1);}
.tab.a2{color:var(--day2);border-bottom-color:var(--day2);}
.tab.a3{color:var(--day3);border-bottom-color:var(--day3);}
.tab.a4{color:var(--day4);border-bottom-color:var(--day4);}
​
/* LAYOUT */
.wrap{display:grid;grid-template-columns:220px 1fr;min-height:calc(100vh - 160px);}
.sidebar{background:var(--surface);border-right:1px solid var(--border);padding:24px 0;position:sticky;top:47px;height:calc(100vh - 47px);overflow-y:auto;}
.sb-section{margin-bottom:6px;}
.sb-label{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--text-muted);padding:8px 20px 4px;text-transform:uppercase;}
.sb-link{display:block;padding:6px 20px;font-size:12px;color:var(--text-dim);cursor:pointer;transition:all .15s;border-left:2px solid transparent;}
.sb-link:hover{color:var(--text);background:var(--surface2);}
.sb-link.active{color:var(--accent);border-left-color:var(--accent);background:rgba(56,189,248,.05);}
​
.main{padding:40px 48px;max-width:900px;}
​
/* SECTIONS */
.day-section{display:none;}
.day-section.active{display:block;}
​
.sec-header{margin-bottom:36px;padding-bottom:20px;border-bottom:1px solid var(--border);}
.sec-label{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;}
.d1 .sec-label{color:var(--day1);}
.d2 .sec-label{color:var(--day2);}
.d3 .sec-label{color:var(--day3);}
.d4 .sec-label{color:var(--day4);}
.sec-header h2{font-size:26px;font-weight:900;letter-spacing:-.5px;}
.sec-header p{color:var(--text-dim);margin-top:8px;font-size:13px;}
​
/* TOPICS */
.topic{margin-bottom:40px;scroll-margin-top:60px;}
.topic-title{font-size:17px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.topic-icon{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.d1 .topic-icon{background:rgba(56,189,248,.12);}
.d2 .topic-icon{background:rgba(129,140,248,.12);}
.d3 .topic-icon{background:rgba(52,211,153,.12);}
.d4 .topic-icon{background:rgba(245,158,11,.12);}
​
/* CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:24px;margin-bottom:16px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;}
.d1 .card::before{background:var(--day1);}
.d2 .card::before{background:var(--day2);}
.d3 .card::before{background:var(--day3);}
.d4 .card::before{background:var(--day4);}
.card h4{font-size:14px;font-weight:700;margin-bottom:12px;color:var(--text);}
​
/* CODE */
.code{background:#050a12;border:1px solid #162030;border-radius:6px;padding:18px 20px;font-family:'JetBrains Mono',monospace;font-size:12.5px;line-height:1.75;overflow-x:auto;margin:10px 0;position:relative;}
.code-label{position:absolute;top:8px;right:12px;font-size:10px;color:var(--text-muted);letter-spacing:1px;text-transform:uppercase;font-family:'Noto Sans JP',sans-serif;}
.cm{color:#3d5a7a;}.kw{color:#79b8ff;}.st{color:#9ecbff;}.an{color:#b392f0;}.tp{color:#f97583;}.mt{color:#b392f0;}.pm{color:#ffab70;}.vl{color:#79b8ff;}.hl{color:#38bdf8;}
​
/* TABLE */
.tbl-wrap{overflow-x:auto;margin:10px 0;}
table{width:100%;border-collapse:collapse;font-size:12.5px;}
th{background:var(--surface2);padding:9px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:1px;color:var(--text-muted);border-bottom:1px solid var(--border);text-transform:uppercase;white-space:nowrap;}
td{padding:9px 14px;border-bottom:1px solid rgba(30,45,69,.5);color:var(--text-dim);vertical-align:top;line-height:1.6;}
td:first-child{color:var(--text);font-weight:500;white-space:nowrap;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(255,255,255,.015);}
​
/* ALERTS */
.alert{border-radius:6px;padding:12px 16px;margin:10px 0;font-size:13px;display:flex;gap:10px;align-items:flex-start;line-height:1.65;}
.ai{font-size:15px;flex-shrink:0;margin-top:1px;}
.aw{background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.22);color:#fbbf24;}
.ai-info{background:rgba(56,189,248,.06);border:1px solid rgba(56,189,248,.18);color:var(--text-dim);}
.as{background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.22);color:#6ee7b7;}
.ae{background:rgba(248,113,113,.07);border:1px solid rgba(248,113,113,.22);color:#fca5a5;}
​
/* LISTS */
ul.pts,ol.pts{padding-left:18px;}
ul.pts li,ol.pts li{margin-bottom:7px;color:var(--text-dim);font-size:13px;line-height:1.7;}
ul.pts li strong,ol.pts li strong{color:var(--text);}
​
/* STEP LIST */
.steps{list-style:none;padding:0;}
.steps li{display:flex;gap:12px;margin-bottom:10px;padding:13px 16px;background:var(--surface2);border-radius:6px;border:1px solid var(--border);align-items:flex-start;}
.snum{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;margin-top:2px;}
.d1 .snum{background:rgba(56,189,248,.18);color:var(--day1);}
.d2 .snum{background:rgba(129,140,248,.18);color:var(--day2);}
.d3 .snum{background:rgba(52,211,153,.18);color:var(--day3);}
.d4 .snum{background:rgba(245,158,11,.18);color:var(--day4);}
.scontent strong{display:block;font-size:13px;color:var(--text);margin-bottom:3px;}
.scontent span{font-size:12px;color:var(--text-muted);line-height:1.6;}
​
/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
@media(max-width:700px){.g2,.g3{grid-template-columns:1fr;}.wrap{grid-template-columns:1fr;}.sidebar{display:none;}.main{padding:24px 20px;}}
.mini{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:14px 16px;}
.mini h5{font-size:12px;font-weight:700;margin-bottom:6px;color:var(--text);}
.mini p{font-size:12px;color:var(--text-muted);line-height:1.65;}
​
/* TAGS */
.tag{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;letter-spacing:1px;vertical-align:middle;margin-left:6px;text-transform:uppercase;}
.tm{background:rgba(248,113,113,.14);color:#f87171;border:1px solid rgba(248,113,113,.28);}
.tp2{background:rgba(245,158,11,.1);color:#fbbf24;border:1px solid rgba(245,158,11,.28);}
.tg{background:rgba(52,211,153,.1);color:#34d399;border:1px solid rgba(52,211,153,.25);}
​
/* CHECKLIST */
.cklist{list-style:none;padding:0;}
.cklist li{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid rgba(30,45,69,.5);font-size:13px;color:var(--text-dim);}
.cklist li:last-child{border-bottom:none;}
.chk{width:17px;height:17px;border:1.5px solid var(--border2);border-radius:4px;flex-shrink:0;margin-top:2px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:9px;}
.chk:hover{border-color:var(--accent);}
.chk.done{background:var(--accent4);border-color:var(--accent4);color:#fff;}
​
hr{border:none;border-top:1px solid var(--border);margin:20px 0;}
p.lead{color:var(--text-dim);font-size:13px;margin-bottom:12px;line-height:1.75;}
.divider{height:1px;background:var(--border);margin:28px 0;}
code.inline{background:rgba(56,189,248,.1);color:var(--accent);font-family:'JetBrains Mono',monospace;font-size:11.5px;padding:1px 6px;border-radius:3px;}
​
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
</style>
</head>

    <div class="card">
      <h4>フロントエンドのバリデーション vs バックエンドのバリデーション</h4>
      <p class="lead">「クライアント（ブラウザ）側でチェックするか・サーバー（API）側でチェックするか」の役割分担を理解する。</p>
      <div class="tbl-wrap">
        <table>
          <tr><th>種別</th><th>実装場所</th><th>目的</th><th>例</th></tr>
          <tr><td>フロントエンドバリデーション</td><td>TypeScript / React Hook Form等</td><td>UX向上・APIコール削減</td><td>必須チェック・桁数・形式チェック</td></tr>
          <tr><td>バックエンドバリデーション</td><td>Spring Boot（@Valid）</td><td>セキュリティ・データ整合性の保証</td><td>必須・形式・業務ルール・DBチェック</td></tr>
        </table>
      </div>
      <div class="alert ae"><span class="ai">🚫</span><span>フロントエンドのバリデーションは<strong>あくまでUX改善</strong>。「フロントでチェックしているからバックエンドは不要」は絶対にNG。APIは直接叩けるので、バックエンドのバリデーションは必ず実装する。</span></div>
​
      <div class="code"><span class="cm">// React Hook Form + zodでのフロントエンドバリデーション例</span>
<span class="kw">import</span> { useForm } <span class="kw">from</span> <span class="st">'react-hook-form'</span>;
<span class="kw">import</span> { z } <span class="kw">from</span> <span class="st">'zod'</span>;
<span class="kw">import</span> { zodResolver } <span class="kw">from</span> <span class="st">'@hookform/resolvers/zod'</span>;
​
<span class="cm">// バリデーションスキーマ（設計書の項目定義から作る）</span>
<span class="kw">const</span> schema = z.<span class="mt">object</span>({
  name: z.<span class="mt">string</span>()
    .<span class="mt">min</span>(<span class="vl">1</span>, <span class="st">'氏名は必須です'</span>)
    .<span class="mt">max</span>(<span class="vl">50</span>, <span class="st">'氏名は50文字以内です'</span>),
  email: z.<span class="mt">string</span>()
    .<span class="mt">min</span>(<span class="vl">1</span>, <span class="st">'メールアドレスは必須です'</span>)
    .<span class="mt">email</span>(<span class="st">'メールアドレスの形式が不正です'</span>),
  age: z.<span class="mt">number</span>()
    .<span class="mt">min</span>(<span class="vl">0</span>).<span class="mt">max</span>(<span class="vl">150</span>)
    .<span class="mt">optional</span>(),
});
​
<span class="kw">type</span> <span class="tp">UserFormValues</span> = z.<span class="mt">infer</span>&lt;<span class="kw">typeof</span> schema&gt;;
​
<span class="kw">const</span> <span class="tp">UserForm</span> = () =&gt; {
  <span class="kw">const</span> { register, handleSubmit, formState: { errors, isSubmitting } }
    = <span class="mt">useForm</span>&lt;<span class="tp">UserFormValues</span>&gt;({ resolver: <span class="mt">zodResolver</span>(schema) });
​
  <span class="kw">const</span> <span class="mt">onSubmit</span> = <span class="kw">async</span> (data: <span class="tp">UserFormValues</span>) =&gt; {
    <span class="kw">await</span> <span class="mt">createUser</span>(data);
  };
​
  <span class="kw">return</span> (
    &lt;form onSubmit={<span class="mt">handleSubmit</span>(onSubmit)}&gt;
      &lt;input {...<span class="mt">register</span>(<span class="st">'name'</span>)} /&gt;
      {errors.name &amp;&amp; &lt;span&gt;{errors.name.message}&lt;/span&gt;}
​
      &lt;button type=<span class="st">"submit"</span> disabled={isSubmitting}&gt;   {<span class="cm">/* 送信中は無効化 */</span>}
        {isSubmitting ? <span class="st">'送信中...'</span> : <span class="st">'登録'</span>}
      &lt;/button&gt;
    &lt;/form&gt;
  );
};</div>
    </div>
  </div>

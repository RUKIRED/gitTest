      <div class="code"><span class="cm">// イベント定義表（こういう書き方で来ることが多い）</span>
​
イベントID: EVT-001
トリガー   : 「登録」ボタン押下
前提条件   : 必須項目が全て入力されている
処理内容   :
  1. 入力値のバリデーションチェック（クライアント側）
  2. POST /api/users を呼び出す
  3. 成功(201)の場合 → 完了画面（SCR-002）へ遷移
  4. バリデーションエラー(400)の場合 → エラーメッセージを各入力欄の下に表示
  5. 業務エラー(409)の場合 → 画面上部にエラーバナーを表示
  6. システムエラー(500)の場合 → エラーダイアログを表示
​
<span class="cm">// ↑ これをそのままTypeScriptのonSubmit関数に落とし込む</span></div>
​
      <div class="code"><span class="cm">// 上記イベント定義をTypeScriptで実装した例</span>
<span class="kw">const</span> <span class="mt">handleSubmit</span> = <span class="kw">async</span> (data: <span class="tp">UserCreateRequest</span>) =&gt; {
  <span class="kw">try</span> {
    <span class="cm">// 処理2: API呼び出し</span>
    <span class="kw">await</span> <span class="mt">createUser</span>(data);
    <span class="cm">// 処理3: 成功 → 完了画面へ遷移</span>
    router.<span class="mt">push</span>(<span class="st">'/users/complete'</span>);
​
  } <span class="kw">catch</span> (error) {
    <span class="kw">if</span> (error.status === <span class="vl">400</span>) {
      <span class="cm">// 処理4: バリデーションエラー → 各フィールドにエラー表示</span>
      <span class="mt">setFieldErrors</span>(error.errors);
    } <span class="kw">else if</span> (error.status === <span class="vl">409</span>) {
      <span class="cm">// 処理5: 業務エラー → バナー表示</span>
      <span class="mt">setBannerError</span>(error.message);
    } <span class="kw">else</span> {
      <span class="cm">// 処理6: システムエラー → ダイアログ表示</span>
      <span class="mt">setDialogError</span>(<span class="st">'システムエラーが発生しました'</span>);
    }
  }
};</div>

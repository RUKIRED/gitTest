          <tr><td>ユーザーID</td><td>user_id</td><td>BIGINT</td><td>PK, AUTO_INCREMENT</td></tr>
          <tr><td>氏名</td><td>name</td><td>VARCHAR(50)</td><td>NOT NULL</td></tr>
          <tr><td>メールアドレス</td><td>email</td><td>VARCHAR(255)</td><td>NOT NULL, UNIQUE</td></tr>
